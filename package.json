{
  "name": "paleodraw",
  "version": "0.3.0",
  "description": "A specialized vector drawing application for creating precise paleontological illustrations and scientific diagrams",
  "main": "electron/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "concurrently \"npm run dev --prefix frontend\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build --prefix frontend",
    "start": "cross-env NODE_ENV=production electron .",
    "dist": "electron-builder"
  },
  "keywords": [
    "paleontology",
    "vector-drawing",
    "scientific-illustration",
    "fossil-drawing",
    "spline-editor",
    "electron",
    "desktop-app"
  ],
  "author": "Amine Lahnin",
  "license": "ISC",
  "dependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "wait-on": "^9.0.1"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.1",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "electron": "^38.4.0"
  },
  "build": {
    "appId": "com.aminelahnin.paleodraw",
    "productName": "PaleoDraw",
    "files": [
      "electron/",
      "frontend/",
      "package.json"
    ],
    "directories": {
      "buildResources": "frontend/public"
    },
    "win": {
      "target": "nsis",
      "icon": "frontend/public/logo.ico"
    }
  }
}
